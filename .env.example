# ========================
# FOT System Configuration
# ========================

# REQUIRED: Set a strong secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# REQUIRED (production): separate key for encrypting integration secrets at rest.
# Keep this value different from SECRET_KEY.
SECRETS_ENCRYPTION_KEY=

# REQUIRED (production): separate key for signing refresh tokens.
# Must be different from SECRET_KEY. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
REFRESH_SECRET_KEY=

# JWT settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin credentials (only used during first init_db.py run)
# If ADMIN_PASSWORD is not set, a random one will be generated and printed to console
ADMIN_EMAIL=admin
ADMIN_PASSWORD=

# Database URL
# Dev with docker-compose.dev.yml: postgresql://fot_admin:fot_pass@localhost:5433/fot_db
# Alternative local fallback (without Docker): sqlite:///./fot.db
DATABASE_URL=postgresql://fot_admin:fot_pass@localhost:5433/fot_db

# Database Migrations (Run after changing DATABASE_URL or models):
# 1. Generate: python -m alembic revision --autogenerate -m "description"
# 2. Apply: python -m alembic upgrade head

# CORS Origins (comma-separated)
# For production: https://your-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Environment: development | production
ENVIRONMENT=development

# Trusted reverse proxies (comma-separated IPs/CIDRs)
# Example (Docker bridge + localhost): 127.0.0.1,::1,172.16.0.0/12
TRUSTED_PROXY_IPS=127.0.0.1,::1

# Uvicorn forwarded allow list (must align with trusted proxies)
FORWARDED_ALLOW_IPS=127.0.0.1

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
